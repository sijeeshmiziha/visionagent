{
  "name": "visionagent",
  "version": "0.0.1",
  "description": "The most complete AI agent framework for design-to-code. Convert Figma designs to production React + Tailwind with multi-provider AI support, 15 Figma tools, and autonomous agents.",
  "author": {
    "name": "sijeeshmiziha",
    "email": "sijeeshmonbalan@gmail.com",
    "url": "https://github.com/sijeeshmiziha"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sijeeshmiziha/visionagent.git"
  },
  "homepage": "https://github.com/sijeeshmiziha/visionagent",
  "bugs": {
    "url": "https://github.com/sijeeshmiziha/visionagent/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run typecheck && npm run lint && tsup",
    "dev": "tsup --watch",
    "test": "vitest run tests/unit tests/tools tests/core",
    "test:unit": "vitest run tests/unit tests/tools tests/core",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "example": "tsx --env-file=.env",
    "example:interactive": "tsx --env-file=.env examples/run.ts",
    "tokens": "tsx .scripts/token-calculator.ts",
    "tokens:verbose": "tsx .scripts/token-calculator.ts --verbose",
    "tokens:json": "tsx .scripts/token-calculator.ts --json",
    "ci": "npm run typecheck && npm run lint && npm run test:unit && npm run build",
    "prepublishOnly": "npm run ci",
    "prepare": "husky"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "vision",
    "agents",
    "tools",
    "ai-sdk",
    "openai",
    "anthropic",
    "google",
    "figma",
    "react",
    "tailwind",
    "design-to-code",
    "figma-to-react",
    "code-generation",
    "jsx",
    "tailwindcss"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ai": "^6.0.0",
    "colord": "^2.9.3",
    "css-what": "^7.0.0",
    "htmltojsx": "^0.3.0",
    "postcss": "^8.5.8",
    "postcss-safe-parser": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@inquirer/prompts": "^7.2.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/htmltojsx": "^0.0.33",
    "@types/node": "^25.2.0",
    "@types/postcss-safe-parser": "^5.0.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.40.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
